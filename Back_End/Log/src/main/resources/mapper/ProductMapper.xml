<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.auth.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.example.auth.model.Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" parameterType="Long" resultMap="ProductResultMap">
        SELECT id, name, price, stock, description, created_at, updated_at
        FROM products
        WHERE id = #{id}
    </select>

    <select id="findByName" parameterType="String" resultMap="ProductResultMap">
        SELECT id, name, price, stock, description, created_at, updated_at
        FROM products
        WHERE name = #{name}
        LIMIT 1
    </select>

    <select id="findAll" resultMap="ProductResultMap">
        SELECT id, name, price, stock, description, created_at, updated_at
        FROM products
        ORDER BY id
    </select>

</mapper>
