<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.auth.mapper.UserMapper">

    <select id="findByPhoneNumber" parameterType="String" resultType="com.example.auth.model.User">
        SELECT * FROM users WHERE phone_number = #{phoneNumber}
    </select>

    <select id="findByUserName" parameterType="String" resultType="com.example.auth.model.User">
        SELECT * FROM users WHERE username = #{username}
    </select>

    <insert id="insertUser" parameterType="com.example.auth.model.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users(username, phone_number, password_hash, status, created_at, updated_at)
        VALUES(#{username}, #{phoneNumber}, #{passwordHash}, #{status}, NOW(), NOW())
    </insert>

    <update id="updateLastLogin" parameterType="map">
        UPDATE users SET last_login = #{lastLogin}, updated_at = NOW() WHERE id = #{id}
    </update>

</mapper>